{
  "name": "platinum-place/laravel-dgii",
  "type": "library",
  "description": "Integration package for DGII (Electronic Invoicing e-CF) Dominican Republic. Automated signature, authentication, and submission for standard, consumption, and range cancellation documents.",
  "keywords": [
    "laravel",
    "DGII",
    "e-CF",
    "facturación-electrónica",
    "dominican-republic"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-dom": "*",
    "ext-gd": "*",
    "ext-simplexml": "*",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0",
    "platinum-place/php-dgii-xml-signer": "^1.0",
    "ext-libxml": "*"
  },
  "require-dev": {
    "laravel/pint": "^1.21",
    "orchestra/testbench": "^9.0|^10.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "PlatinumPlace\\LaravelDgii\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PlatinumPlace\\LaravelDgii\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "PlatinumPlace\\LaravelDgii\\Providers\\AppServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
