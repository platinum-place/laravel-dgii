# Ambiente de la DGII (testecf, certecf, ecf)
DGII_ENVIRONMENT=testecf

# Credenciales de Firma Electrónica
DGII_CERT_PATH=storage/dgii/certs/certificate.p12
DGII_KEY_PASSWORD=

# Api Key para servicios de estatus
DGII_API_KEY=

# Dominios de servicios (Opcional, tiene valores por defecto)
# DGII_DOMAIN_ECF=https://ecf.dgii.gov.do
# DGII_DOMAIN_FC=https://fc.dgii.gov.do
# DGII_DOMAIN_STATUS=https://statusecf.dgii.gov.do

# Configuración de Almacenamiento
DGII_STORAGE_DISK=local
DGII_STORAGE_PATH=dgii/xmls

# Reglas de Negocio
DGII_FC_TYPE=32
DGII_FC_LIMIT=250000

# Configuración de Caché
DGII_CACHE_PREFIX=dgii_token_
DGII_CACHE_BUFFER=600